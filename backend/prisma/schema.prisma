generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  FINANCE
}

enum AttendanceEventType {
  CHECK_IN
  CHECK_OUT
}

model Tenant {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  branches              Branch[]
  deals                 Deal[]
  leads                 Lead[]
  proposals             Proposal[]
  users                 User[]
  activities            Activity[]
  notes                 Note[]
  auditLogs             AuditLog[]
  sites                 Site[]
  guards                Guard[]
  shifts                Shift[]
  availabilities        Availability[]
  clients               Client[]
  clientUsers           ClientUser[]
  comments              ProposalComment[]
  documents             SharedDocument[]
  attendanceEvents      AttendanceEvent[]
  incidents             Incident[]
  dailyServiceReports   DailyServiceReport[]
  invoices              Invoice[]
  invoiceDisputes       InvoiceDispute[]
  timesheets            Timesheet[]
  rateCards             RateCard[]
  recommendationActions RecommendationAction[]
  aiGenerations         AiGeneration[]
  aiFeedback            AiFeedback[]
  promptVersions        PromptVersion[]
  knowledgeEntries      KnowledgeEntry[]
  aiConversations       AiConversation[]
  discoverySessions     DiscoverySession[]
  salesAssessments      SalesAssessment[]
  roles                 Role[]
  userRoleAssignments   UserRoleAssignment[]
  fieldPermissions      FieldPermission[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  apiRequestLogs        ApiRequestLog[]
  ssoProviders          SSOProvider[]
  ssoLoginStates        SSOLoginState[]
  userSessions          UserSession[]
  branding              TenantBranding?
  customDomains         CustomDomain[]
  checkpoints           Checkpoint[]
  patrolRoutes          PatrolRoute[]
  patrolRuns            PatrolRun[]
  patrolEvents          PatrolEvent[]
  guardSyncQueues       GuardSyncQueue[]
}

model Branch {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  name            String
  location        String
  managerId       String?              @map("manager_id")
  manager         User?                @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  status          String               @default("active")
  createdAt       DateTime             @default(now()) @map("created_at")
  users           User[]               @relation("UserBranch")
  clients         Client[]
  sites           Site[]
  guards          Guard[]
  shifts          Shift[]
  incidents       Incident[]
  reports         DailyServiceReport[]
  invoices        Invoice[]
  roleAssignments UserRoleAssignment[]

  @@index([tenantId])
  @@index([managerId])
  @@index([tenantId, status])
  @@map("Branch")
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  password          String
  name              String?
  refreshToken      String?
  role              UserRole             @default(ADMIN)
  tenantId          String
  branchId          String?              @map("branch_id")
  branch            Branch?              @relation("UserBranch", fields: [branchId], references: [id], onDelete: SetNull)
  managedBranches   Branch[]             @relation("BranchManager")
  isSuperAdmin      Boolean              @default(true) @map("is_super_admin")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  reviewedIncidents Incident[]           @relation("IncidentReviewer")
  roleAssignments   UserRoleAssignment[]
  sessions          UserSession[]

  @@index([tenantId])
  @@index([branchId])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String?
  module      String
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@index([module])
  @@map("Permission")
}

model Role {
  id               String               @id @default(uuid())
  tenantId         String               @map("tenant_id")
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  isSystemRole     Boolean              @default(false) @map("is_system_role")
  isActive         Boolean              @default(true) @map("is_active")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  permissions      RolePermission[]
  assignments      UserRoleAssignment[]
  fieldPermissions FieldPermission[]

  @@unique([tenantId, name], map: "Role_tenant_name_key")
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("Role")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now()) @map("assigned_at")

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}

model UserRoleAssignment {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String    @map("role_id")
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branchId   String?   @map("branch_id")
  branch     Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedBy String?   @map("assigned_by")
  isActive   Boolean   @default(true) @map("is_active")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")

  @@unique([userId, roleId, branchId], map: "UserRoleAssignment_user_role_branch_key")
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([branchId])
  @@map("UserRoleAssignment")
}

model FieldPermission {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  entity    String
  field     String
  canView   Boolean  @default(true) @map("can_view")
  canEdit   Boolean  @default(true) @map("can_edit")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roleId, entity, field], map: "FieldPermission_role_entity_field_key")
  @@index([tenantId])
  @@index([roleId])
  @@index([tenantId, entity])
  @@map("FieldPermission")
}

model Lead {
  id                String             @id @default(uuid())
  name              String
  company           String
  status            String             @default("new")
  tenantId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  email             String?
  deals             Deal[]
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  proposals         Proposal[]
  notes             Note[]
  discoverySessions DiscoverySession[]
  salesAssessments  SalesAssessment[]

  @@index([tenantId])
}

model Deal {
  id                String             @id @default(uuid())
  name              String
  stage             String             @default("new")
  tenantId          String
  leadId            String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lead              Lead               @relation(fields: [leadId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  activities        Activity[]
  notes             Note[]
  proposals         Proposal[]
  clientId          String?
  client            Client?            @relation(fields: [clientId], references: [id])
  discoverySessions DiscoverySession[]
  salesAssessments  SalesAssessment[]

  @@index([tenantId])
  @@index([leadId])
  @@index([clientId])
}

model Note {
  id        String   @id @default(uuid())
  content   String
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Activity {
  id          String    @id @default(uuid())
  type        String // call, meeting, task
  subject     String
  description String?
  status      String    @default("pending") // pending, completed
  dueDate     DateTime?
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([tenantId])
}

model Proposal {
  id        String            @id @default(uuid())
  title     String
  content   String
  status    String            @default("draft")
  tenantId  String
  dealId    String?
  leadId    String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  lead      Lead?             @relation(fields: [leadId], references: [id])
  deal      Deal?             @relation(fields: [dealId], references: [id])
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  versions  ProposalVersion[]
  clientId  String?
  client    Client?           @relation(fields: [clientId], references: [id])
  comments  ProposalComment[]

  @@index([tenantId])
  @@index([leadId])
  @@index([dealId])
  @@index([clientId])
}

model ProposalVersion {
  id            String   @id @default(uuid())
  proposalId    String
  proposal      Proposal @relation(fields: [proposalId], references: [id])
  content       String
  versionNumber Int
  createdAt     DateTime @default(now())

  @@index([proposalId])
}

model DiscoverySession {
  id                String            @id @default(uuid())
  tenantId          String            @map("tenant_id")
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId            String?           @map("lead_id")
  lead              Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  dealId            String?           @map("deal_id")
  deal              Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  propertyType      String?           @map("property_type")
  buyerRole         String?           @map("buyer_role")
  currentProvider   String?           @map("current_provider")
  guardCount        Int?              @map("guard_count")
  serviceHours      String?           @map("service_hours")
  painPoints        String[]          @default([]) @map("pain_points")
  riskConcerns      String[]          @default([]) @map("risk_concerns")
  decisionTimeline  String?           @map("decision_timeline")
  budgetSensitivity String?           @map("budget_sensitivity")
  objections        String[]          @default([])
  notes             String?
  createdBy         String?           @map("created_by")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  assessments       SalesAssessment[]

  @@index([tenantId])
  @@index([leadId])
  @@index([dealId])
  @@index([tenantId, leadId])
  @@index([tenantId, dealId])
  @@map("DiscoverySession")
}

model SalesAssessment {
  id                    String            @id @default(uuid())
  tenantId              String            @map("tenant_id")
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId                String?           @map("lead_id")
  lead                  Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  dealId                String?           @map("deal_id")
  deal                  Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  discoverySessionId    String?           @map("discovery_session_id")
  discoverySession      DiscoverySession? @relation(fields: [discoverySessionId], references: [id], onDelete: SetNull)
  assessmentType        String            @default("sales_assessment") @map("assessment_type")
  leadScore             Int?              @map("lead_score")
  priorityTier          String?           @map("priority_tier")
  closeReadinessScore   Int?              @map("close_readiness_score")
  discoveryQualityScore Int?              @map("discovery_quality_score")
  riskProfile           String?           @map("risk_profile")
  proposalAngle         String?           @map("proposal_angle")
  recommendedNextAction String?           @map("recommended_next_action")
  missingQuestions      String[]          @default([]) @map("missing_questions")
  objectionRisks        String[]          @default([]) @map("objection_risks")
  summary               String?
  generatedOutput       Json?             @map("generated_output")
  aiGenerationId        String?           @map("ai_generation_id")
  createdBy             String?           @map("created_by")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([leadId])
  @@index([dealId])
  @@index([discoverySessionId])
  @@index([tenantId, assessmentType])
  @@index([tenantId, createdAt])
  @@map("SalesAssessment")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Site {
  id                  String               @id @default(uuid())
  name                String
  address             String
  instructions        String?
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  branchId            String?              @map("branch_id")
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clientId            String?              @map("client_id")
  client              Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  shifts              Shift[]
  incidents           Incident[]
  dailyServiceReports DailyServiceReport[]
  invoices            Invoice[]
  timesheets          Timesheet[]
  rateCards           RateCard[]
  createdAt           DateTime             @default(now())
  checkpoints         Checkpoint[]
  patrolRoutes        PatrolRoute[]

  @@index([tenantId])
  @@index([branchId])
  @@index([clientId])
}

model Guard {
  id               String            @id @default(uuid())
  name             String
  phone            String?
  email            String?
  passwordHash     String?           @map("password_hash")
  salary           Float?
  bankDetails      String?           @map("bank_details")
  documents        String?
  personalNotes    String?           @map("personal_notes")
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  branchId         String?           @map("branch_id")
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignments      Assignment[]
  availability     Availability?
  attendanceEvents AttendanceEvent[]
  incidents        Incident[]
  invoiceItems     InvoiceItem[]
  timesheets       Timesheet[]
  createdAt        DateTime          @default(now())
  patrolRuns       PatrolRun[]
  patrolEvents     PatrolEvent[]
  syncQueues       GuardSyncQueue[]

  @@index([tenantId])
  @@index([branchId])
  @@index([email])
  @@index([phone])
}

model Shift {
  id               String            @id @default(uuid())
  siteId           String
  site             Site              @relation(fields: [siteId], references: [id])
  startTime        DateTime
  endTime          DateTime
  requiredGuards   Int
  status           String            @default("open")
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  branchId         String?           @map("branch_id")
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignments      Assignment[]
  attendanceEvents AttendanceEvent[]
  incidents        Incident[]
  invoiceItems     InvoiceItem[]
  timesheets       Timesheet[]
  createdAt        DateTime          @default(now())
  patrolRuns       PatrolRun[]

  @@index([tenantId])
  @@index([branchId])
  @@index([siteId])
}

model Assignment {
  id        String   @id @default(uuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  guardId   String
  guard     Guard    @relation(fields: [guardId], references: [id])
  status    String   @default("pending") // pending, confirmed...
  createdAt DateTime @default(now())

  @@index([shiftId])
  @@index([guardId])
}

model Availability {
  id        String    @id @default(uuid())
  guardId   String    @unique
  guard     Guard     @relation(fields: [guardId], references: [id])
  status    String    @default("available") // available, unavailable
  startDate DateTime?
  endDate   DateTime?
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([guardId])
  @@index([tenantId])
}

model AttendanceEvent {
  id        String              @id @default(uuid())
  guardId   String
  guard     Guard               @relation(fields: [guardId], references: [id])
  shiftId   String
  shift     Shift               @relation(fields: [shiftId], references: [id])
  type      AttendanceEventType
  timestamp DateTime            @default(now())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  notes     String?
  source    String              @default("guard_portal")
  createdAt DateTime            @default(now())

  @@unique([guardId, shiftId, type])
  @@index([tenantId])
  @@index([guardId])
  @@index([shiftId])
}

model Incident {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  branchId      String?   @map("branch_id")
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  shiftId       String    @map("shift_id")
  shift         Shift     @relation(fields: [shiftId], references: [id])
  siteId        String    @map("site_id")
  site          Site      @relation(fields: [siteId], references: [id])
  guardId       String    @map("guard_id")
  guard         Guard     @relation(fields: [guardId], references: [id])
  title         String
  description   String
  severity      String    @default("low")
  status        String    @default("submitted")
  occurredAt    DateTime  @map("occurred_at")
  attachmentUrl String?   @map("attachment_url")
  notes         String?
  reviewedById  String?   @map("reviewed_by")
  reviewedBy    User?     @relation("IncidentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime? @map("reviewed_at")
  reviewNote    String?   @map("review_note")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([shiftId])
  @@index([siteId])
  @@index([guardId])
  @@index([reviewedById])
  @@index([severity])
  @@index([status])
  @@map("Incident")
}

model Client {
  id                  String               @id @default(uuid())
  name                String
  companyName         String?
  email               String
  phone               String?
  billingNotes        String?              @map("billing_notes")
  internalNotes       String?              @map("internal_notes")
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  branchId            String?              @map("branch_id")
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  users               ClientUser[]
  deals               Deal[]
  proposals           Proposal[]
  documents           SharedDocument[]
  sites               Site[]
  dailyServiceReports DailyServiceReport[]
  invoices            Invoice[]
  invoiceDisputes     InvoiceDispute[]
  timesheets          Timesheet[]
  rateCards           RateCard[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([tenantId])
  @@index([branchId])
}

model DailyServiceReport {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  branchId    String?   @map("branch_id")
  branch      Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clientId    String    @map("client_id")
  client      Client    @relation(fields: [clientId], references: [id])
  siteId      String    @map("site_id")
  site        Site      @relation(fields: [siteId], references: [id])
  reportDate  DateTime  @map("report_date")
  summary     String
  status      String    @default("draft")
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([clientId])
  @@index([siteId])
  @@index([reportDate])
  @@index([status])
  @@map("DailyServiceReport")
}

model Invoice {
  id                  String           @id @default(uuid())
  tenantId            String           @map("tenant_id")
  tenant              Tenant           @relation(fields: [tenantId], references: [id])
  branchId            String?          @map("branch_id")
  branch              Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clientId            String           @map("client_id")
  client              Client           @relation(fields: [clientId], references: [id])
  siteId              String           @map("site_id")
  site                Site             @relation(fields: [siteId], references: [id])
  invoiceNumber       String           @map("invoice_number")
  billingStartDate    DateTime         @map("billing_start_date")
  billingEndDate      DateTime         @map("billing_end_date")
  totalHours          Float            @map("total_hours")
  hourlyRate          Float            @map("hourly_rate")
  subtotal            Float
  tax                 Float
  totalAmount         Float            @map("total_amount")
  status              String           @default("draft")
  createdAt           DateTime         @default(now()) @map("created_at")
  issuedAt            DateTime?        @map("issued_at")
  paidAt              DateTime?        @map("paid_at")
  dueDate             DateTime?        @map("due_date")
  internalAdjustments String?          @map("internal_adjustments")
  rateCardId          String?          @map("rate_card_id")
  rateCard            RateCard?        @relation(fields: [rateCardId], references: [id], onDelete: SetNull)
  rateSource          String           @default("manual") @map("rate_source")
  items               InvoiceItem[]
  disputes            InvoiceDispute[]

  @@unique([tenantId, invoiceNumber], map: "Invoice_tenant_invoice_number_key")
  @@unique([tenantId, clientId, siteId, billingStartDate, billingEndDate], map: "Invoice_period_key")
  @@index([tenantId])
  @@index([branchId])
  @@index([clientId])
  @@index([siteId])
  @@index([rateCardId])
  @@index([status])
  @@index([billingStartDate])
  @@index([billingEndDate])
  @@index([issuedAt])
  @@index([paidAt])
  @@index([dueDate])
  @@map("Invoice")
}

model InvoiceDispute {
  id            String    @id @default(uuid())
  invoiceId     String    @map("invoice_id")
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId      String    @map("client_id")
  client        Client    @relation(fields: [clientId], references: [id])
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  reason        String
  description   String
  status        String    @default("open")
  adminResponse String?   @map("admin_response")
  createdAt     DateTime  @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  @@index([invoiceId])
  @@index([clientId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("InvoiceDispute")
}

model InvoiceItem {
  id          String     @id @default(uuid())
  invoiceId   String     @map("invoice_id")
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  timesheetId String?    @map("timesheet_id")
  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id], onDelete: SetNull)
  rateCardId  String?    @map("rate_card_id")
  rateCard    RateCard?  @relation(fields: [rateCardId], references: [id], onDelete: SetNull)
  shiftId     String     @map("shift_id")
  shift       Shift      @relation(fields: [shiftId], references: [id])
  guardId     String     @map("guard_id")
  guard       Guard      @relation(fields: [guardId], references: [id])
  workedHours Float      @map("worked_hours")
  hourlyRate  Float      @map("hourly_rate")
  amount      Float

  @@unique([invoiceId, shiftId, guardId])
  @@index([invoiceId])
  @@index([timesheetId])
  @@index([rateCardId])
  @@index([shiftId])
  @@index([guardId])
