generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deals     Deal[]
  leads     Lead[]
  proposals Proposal[]
  users     User[]
  activities Activity[]
  notes      Note[]
  auditLogs  AuditLog[]
  sites      Site[]
  guards     Guard[]
  shifts     Shift[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String?
  refreshToken String?
  role         UserRole @default(ADMIN)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  company   String
  status    String     @default("new")
  tenantId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  email     String?
  deals     Deal[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  proposals Proposal[]
  notes     Note[]

  @@index([tenantId])
}

model Deal {
  id        String   @id @default(uuid())
  name      String
  stage     String   @default("new")
  tenantId  String
  leadId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead     @relation(fields: [leadId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  activities Activity[]
  notes      Note[]
  proposals  Proposal[]

  @@index([tenantId])
  @@index([leadId])
}

model Note {
  id        String   @id @default(uuid())
  content   String
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Activity {
  id          String   @id @default(uuid())
  type        String   // call, meeting, task
  subject     String
  description String?
  status      String   @default("pending") // pending, completed
  dueDate     DateTime?
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model Proposal {
  id        String   @id @default(uuid())
  title     String
  content   String
  status    String   @default("draft")
  tenantId  String
  dealId    String?
  leadId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead?    @relation(fields: [leadId], references: [id])
  deal      Deal?    @relation(fields: [dealId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  versions  ProposalVersion[]

  @@index([tenantId])
  @@index([leadId])
  @@index([dealId])
}

model ProposalVersion {
  id            String   @id @default(uuid())
  proposalId    String
  proposal      Proposal @relation(fields: [proposalId], references: [id])
  content       String
  versionNumber Int
  createdAt     DateTime @default(now())

  @@index([proposalId])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Site {
  id           String   @id @default(uuid())
  name         String
  address      String
  instructions String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  shifts       Shift[]
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model Guard {
  id          String       @id @default(uuid())
  name        String
  phone       String?
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  assignments Assignment[]
  createdAt   DateTime     @default(now())

  @@index([tenantId])
}

model Shift {
  id             String       @id @default(uuid())
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])
  startTime      DateTime
  endTime        DateTime
  requiredGuards Int
  status         String       @default("open")
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  assignments    Assignment[]
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([siteId])
}

model Assignment {
  id        String   @id @default(uuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  guardId   String
  guard     Guard    @relation(fields: [guardId], references: [id])
  status    String   @default("pending") // pending, confirmed...
  createdAt DateTime @default(now())

  @@index([shiftId])
  @@index([guardId])
}
