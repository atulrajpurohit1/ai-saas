generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum AttendanceEventType {
  CHECK_IN
  CHECK_OUT
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deals     Deal[]
  leads     Lead[]
  proposals Proposal[]
  users     User[]
  activities Activity[]
  notes      Note[]
  auditLogs  AuditLog[]
  sites      Site[]
  guards     Guard[]
  shifts     Shift[]
  availabilities Availability[]
  clients     Client[]
  clientUsers ClientUser[]
  comments    ProposalComment[]
  documents   SharedDocument[]
  attendanceEvents AttendanceEvent[]
  incidents Incident[]
  dailyServiceReports DailyServiceReport[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String?
  refreshToken String?
  role         UserRole @default(ADMIN)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  reviewedIncidents Incident[] @relation("IncidentReviewer")

  @@index([tenantId])
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  company   String
  status    String     @default("new")
  tenantId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  email     String?
  deals     Deal[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  proposals Proposal[]
  notes     Note[]

  @@index([tenantId])
}

model Deal {
  id        String   @id @default(uuid())
  name      String
  stage     String   @default("new")
  tenantId  String
  leadId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead     @relation(fields: [leadId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  activities Activity[]
  notes      Note[]
  proposals  Proposal[]
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([leadId])
  @@index([clientId])
}

model Note {
  id        String   @id @default(uuid())
  content   String
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Activity {
  id          String   @id @default(uuid())
  type        String   // call, meeting, task
  subject     String
  description String?
  status      String   @default("pending") // pending, completed
  dueDate     DateTime?
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model Proposal {
  id        String   @id @default(uuid())
  title     String
  content   String
  status    String   @default("draft")
  tenantId  String
  dealId    String?
  leadId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead?    @relation(fields: [leadId], references: [id])
  deal      Deal?    @relation(fields: [dealId], references: [id])
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  versions  ProposalVersion[]
  clientId  String?
  client    Client?    @relation(fields: [clientId], references: [id])
  comments  ProposalComment[]

  @@index([tenantId])
  @@index([leadId])
  @@index([dealId])
  @@index([clientId])
}

model ProposalVersion {
  id            String   @id @default(uuid())
  proposalId    String
  proposal      Proposal @relation(fields: [proposalId], references: [id])
  content       String
  versionNumber Int
  createdAt     DateTime @default(now())

  @@index([proposalId])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Site {
  id           String   @id @default(uuid())
  name         String
  address      String
  instructions String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  clientId     String?  @map("client_id")
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  shifts       Shift[]
  incidents    Incident[]
  dailyServiceReports DailyServiceReport[]
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([clientId])
}

model Guard {
  id          String       @id @default(uuid())
  name        String
  phone       String?
  email       String?
  passwordHash String?    @map("password_hash")
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  assignments Assignment[]
  availability Availability?
  attendanceEvents AttendanceEvent[]
  incidents Incident[]
  createdAt   DateTime     @default(now())

  @@index([tenantId])
  @@index([email])
  @@index([phone])
}

model Shift {
  id             String       @id @default(uuid())
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])
  startTime      DateTime
  endTime        DateTime
  requiredGuards Int
  status         String       @default("open")
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  assignments    Assignment[]
  attendanceEvents AttendanceEvent[]
  incidents      Incident[]
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([siteId])
}

model Assignment {
  id        String   @id @default(uuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  guardId   String
  guard     Guard    @relation(fields: [guardId], references: [id])
  status    String   @default("pending") // pending, confirmed...
  createdAt DateTime @default(now())

  @@index([shiftId])
  @@index([guardId])
}

model Availability {
  id        String    @id @default(uuid())
  guardId   String    @unique
  guard     Guard     @relation(fields: [guardId], references: [id])
  status    String    @default("available") // available, unavailable
  startDate DateTime?
  endDate   DateTime?
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([guardId])
  @@index([tenantId])
}

model AttendanceEvent {
  id        String              @id @default(uuid())
  guardId   String
  guard     Guard               @relation(fields: [guardId], references: [id])
  shiftId   String
  shift     Shift               @relation(fields: [shiftId], references: [id])
  type      AttendanceEventType
  timestamp DateTime            @default(now())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  notes     String?
  source    String              @default("guard_portal")
  createdAt DateTime            @default(now())

  @@unique([guardId, shiftId, type])
  @@index([tenantId])
  @@index([guardId])
  @@index([shiftId])
}

model Incident {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  shiftId       String   @map("shift_id")
  shift         Shift    @relation(fields: [shiftId], references: [id])
  siteId        String   @map("site_id")
  site          Site     @relation(fields: [siteId], references: [id])
  guardId       String   @map("guard_id")
  guard         Guard    @relation(fields: [guardId], references: [id])
  title         String
  description   String
  severity      String   @default("low")
  status        String   @default("submitted")
  occurredAt    DateTime @map("occurred_at")
  attachmentUrl String?  @map("attachment_url")
  notes         String?
  reviewedById  String?   @map("reviewed_by")
  reviewedBy    User?     @relation("IncidentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime? @map("reviewed_at")
  reviewNote    String?   @map("review_note")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([shiftId])
  @@index([siteId])
  @@index([guardId])
  @@index([reviewedById])
  @@index([severity])
  @@index([status])
  @@map("Incident")
}

model Client {
  id          String   @id @default(uuid())
  name        String
  companyName String?
  email       String
  phone       String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  users       ClientUser[]
  deals       Deal[]
  proposals   Proposal[]
  documents   SharedDocument[]
  sites       Site[]
  dailyServiceReports DailyServiceReport[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model DailyServiceReport {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  clientId    String    @map("client_id")
  client      Client    @relation(fields: [clientId], references: [id])
  siteId      String    @map("site_id")
  site        Site      @relation(fields: [siteId], references: [id])
  reportDate  DateTime  @map("report_date")
  summary     String
  status      String    @default("draft")
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([tenantId])
  @@index([clientId])
  @@index([siteId])
  @@index([reportDate])
  @@index([status])
  @@map("DailyServiceReport")
}

model ClientUser {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  refreshToken String?
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
  @@index([tenantId])
}

model ProposalComment {
  id           String   @id @default(uuid())
  content      String
  proposalId   String
  proposal     Proposal @relation(fields: [proposalId], references: [id])
  userId       String?  // If commented by admin
  clientUserId String? // If commented by client
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())

  @@index([proposalId])
  @@index([tenantId])
}

model SharedDocument {
  id          String   @id @default(uuid())
  name        String
  url         String
  description String?
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  uploadedBy  String   // Admin user ID
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([tenantId])
}
